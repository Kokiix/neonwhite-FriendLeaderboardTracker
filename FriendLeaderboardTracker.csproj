<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>netstandard2.1</TargetFramework>
        <LangVersion>Latest</LangVersion>
        <Authors>Koki</Authors>

        <BepInExPluginGuid>com.koki.FriendLeaderboardTracker</BepInExPluginGuid>
        <BepInExPluginName>FriendLeaderboardTracker</BepInExPluginName>
        <BepInExPluginVersion>1.2.0</BepInExPluginVersion> <!-- x-release-please-version -->

        <BepInExPluginDir>D:\SteamLibrary\steamapps\common\Neon White\BepInEx\plugins</BepInExPluginDir>
        <Thunderstore>.\.thunderstore</Thunderstore>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="BepInEx.Analyzers" Version="*" PrivateAssets="all" />
        <PackageReference Include="BepInEx.Core" Version="*" ExcludeAssets="runtime" />
        <PackageReference Include="BepInEx.AssemblyPublicizer.MSBuild" Version="*" PrivateAssets="all" IncludeAssets="build" />
        <PackageReference Include="BepInEx.PluginInfoProps" Version="*" />
        <PackageReference Include="UnityEngine.Modules" Version="2021.3.45" IncludeAssets="compile" PrivateAssets="all" />
    </ItemGroup>

    <!-- Dependencies -->
    <PropertyGroup>
        <DLLs>D:\SteamLibrary\steamapps\common\Neon White\Neon White_Data\Managed</DLLs>
    </PropertyGroup>
    <ItemGroup>
        <Reference Include="$(DLLs)\Assembly-CSharp.dll" Publicize="true" />
        <Reference Include="$(DLLs)\Assembly-CSharp-firstpass.dll" />

        <Reference Include="$(DLLs)\Unity.InputSystem.dll" /> <!-- for update loop test button  -->
    </ItemGroup>

    <ItemGroup>
        <ModContents Include="$(BepInExPluginDir)\DEVELOPMENT-BUILD-$(BepInExPluginName)\**\*" />
    </ItemGroup>

    <!-- TCLI stuff -->
    <Target Name="TCLI" AfterTargets="Build" Condition="'$(Configuration)' == 'Release' Or '$(Configuration)' == 'Build'">
        <!-- Prepare TCLI -->
        <RemoveDir Condition="Exists('$(Thunderstore)\build')" Directories="$(Thunderstore)\build" />
        <RemoveDir Condition="Exists('$(Thunderstore)\dist')" Directories="$(Thunderstore)\dist" />
        <Copy SourceFiles="@(ModContents)" DestinationFiles="$(Thunderstore)\dist\%(RecursiveDir)%(Filename)%(Extension)" />
        <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(Thunderstore)\dist\" />

        <!-- Publish -->
        <Exec Condition="'$(Configuration)' == 'Release'" Command="tcli publish --config-path $(Thunderstore)\thunderstore.toml --package-version $(BepInExPluginVersion)" />

        <!-- Build -->
        <Exec Condition="'$(Configuration)' == 'Build'" Command="tcli build --config-path $(Thunderstore)\thunderstore.toml --package-version $(BepInExPluginVersion)" />
    </Target>

    <!-- Debug -->
    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
        <IncludeSymbols>true</IncludeSymbols>
        <DebugSymbols>true</DebugSymbols>
        <DebugType>embedded</DebugType>
    </PropertyGroup>
    <Target Name="CopyDLL" AfterTargets="PostBuildEvent" Condition=" '$(Configuration)' == 'Debug' ">
        <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(BepInExPluginDir)\DEVELOPMENT-BUILD-$(BepInExPluginName)" />
    </Target>
</Project>